# Voice Pipeline - .env configuration
# Copy to .env and edit as needed

# ── STT (Speech-to-Text) ──────────────────────────────────
STT_PROVIDER=whisper
WHISPER_MODEL=small
WHISPER_LANGUAGE=en
# For remote STT, set STT_PROVIDER=custom and:
# STT_URL=http://your-stt-server/transcribe

# ── OpenClaw Gateway ──────────────────────────────────────
OPENCLAW_GATEWAY_URL=ws://host.docker.internal:18789
OPENCLAW_TOKEN=your-gateway-token-here
OPENCLAW_AGENT_ID=main

# ── TTS (Text-to-Speech) ─────────────────────────────────
TTS_PROVIDER=edge
TTS_VOICE=en-US-GuyNeural
TTS_LANG=en-US
TTS_FORMAT=audio-24khz-48kbitrate-mono-mp3
# For custom TTS, set TTS_PROVIDER=custom and:
# TTS_URL=http://your-tts-server/synthesize

# ── Audio Input ───────────────────────────────────────────
AUDIO_INPUT_DEVICE=default
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
# For file input instead of mic, set:
# AUDIO_SOURCE=file
# AUDIO_FILE_PATH=/data/input.wav

# ── Pipeline ──────────────────────────────────────────────
PIPELINE_MODE=stream
# stream = continuous listening
# file = process a single file and exit
SILENCE_THRESHOLD_MS=1500
OUTPUT_DIR=/data/output
